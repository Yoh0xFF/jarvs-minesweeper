{
  "name": "jarvs-minesweeper",
  "version": "1.0.0",
  "private": true,
  "description": "JARVS(Just A Rather Very Simple) Minesweeper",
  "homepage": ".",
  "repository": "https://github.com/Yoh0xFF/jarvs-minesweeper",
  "license": "MIT",
  "author": "Ioram Gordadze <Yoh0xFF@gmail.com>",
  "type": "module",
  "scripts": {
    "build": "tsc && vite build",
    "clean": "npx rimraf ./**/dist ./**/node_modules",
    "deploy": "gh-pages -d dist -u 'github-actions-bot <support+actions@github.com>'",
    "format": "prettier --write 'src/**/*.ts' 'src/**/*.tsx' 'src/**/*.scss'",
    "lint": "eslint 'src/**/*.{ts,tsx}'",
    "start": "vite",
    "start:preview": "vite preview",
    "test": "vitest run",
    "test:dev": "vitest dev"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version, not dead"
    ]
  },
  "dependencies": {
    "canvas-confetti": "1.9.4",
    "classnames": "2.5.1",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/canvas-confetti": "1.9.0",
    "@types/node": "25.9.1",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "eslint": "9.39.4",
    "eslint-config-prettier": "9.1.2",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.1.1",
    "gh-pages": "6.3.0",
    "globals": "17.6.0",
    "jsdom": "29.1.1",
    "prettier": "3.8.3",
    "prettier-plugin-organize-imports": "4.3.0",
    "prettier-plugin-packagejson": "3.0.2",
    "sass": "1.100.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.60.0",
    "vite": "8.0.15",
    "vitest": "4.1.8",
    "web-vitals": "5.3.0"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "4.61.0"
  }
}
